        <property name="receives-default">True</property>
        <property name="tooltip-text" translatable="yes">Text and Font</property>
        <property name="action-name">win.dialog-open</property>
        <property name="action-target">'Text'</property>
        <property name="has-frame">False</property>
        <property name="icon-name">dialog-text-and-font</property>
